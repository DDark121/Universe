APP_NAME=Universe Backend API
APP_ENV=dev
APP_DEBUG=true
APP_TIMEZONE=Europe/Moscow

API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100,http://web-admin:3000,http://student-app:3100
CORS_ALLOW_ORIGIN_REGEX=^https://([a-z0-9-]+\\.ngrok-free\\.app|[a-z0-9-]+\\.ngrok\\.app|[a-z0-9-]+\\.ngrok\\.io|[a-z0-9-]+\\.trycloudflare\\.com)$

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=universe
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=<SECRET>

REDIS_URL=redis://redis:6379/0

JWT_SECRET=<SECRET>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=20
REFRESH_TOKEN_EXPIRE_DAYS=14

SERVICE_TOKEN_SECRET=<SECRET>
TG_SERVICE_BASE_URL=http://tg-service:8080
TG_SERVICE_TIMEOUT_SECONDS=5
TG_BOT_USERNAME=universe_bot
OPENROUTER_API_KEY=
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=20
FAQ_ASSISTANT_MODEL=openai/gpt-4.1-mini
FAQ_EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
FAQ_EMBEDDINGS_CACHE_DIR=/var/lib/universe/faq-models
FAQ_SOURCE_DIR=data
FAQ_INDEX_DIR=/var/lib/universe/faq-index
FAQ_ASSISTANT_ENABLED=true
FAQ_AI_TOP_K=4
FAQ_HISTORY_TTL_SECONDS=86400
FAQ_HISTORY_MAX_MESSAGES=8
# Required for Telegram bot polling and WebApp initData validation.
TG_BOT_TOKEN=
TG_POLLING_ENABLED=true
TG_INIT_DATA_TTL_SECONDS=3600
TG_SERVICE_APP_NAME=Universe Telegram Service
TG_SERVICE_APP_DEBUG=false
TG_BACKEND_TIMEOUT_SECONDS=10
BACKEND_API_BASE_URL=http://backend-api:8000/api/v1
# Local origin is http://localhost:3100, but for Telegram this must be the public tunnel URL.
STUDENT_APP_URL=http://localhost:3100
# Frontend build-time URLs.
WEB_ADMIN_VITE_API_BASE_URL=http://localhost:8000/api/v1
# Student mini app uses a single public origin and proxies /api and /tg via student-app nginx.
VITE_API_BASE_URL=/api/v1
VITE_TG_SERVICE_BASE_URL=/tg

ATTACHMENTS_DIR=/var/lib/universe/attachments
ATTACHMENTS_MAX_SIZE_MB=10
AI_IMPORTS_DIR=/var/lib/universe/ai-imports
AI_IMPORT_MAX_SIZE_MB=20
AI_IMPORT_MODEL=openai/gpt-4.1-mini
AI_IMPORT_TIMEOUT_SECONDS=60
AI_IMPORT_MAX_PAGES=20
AI_IMPORT_MAX_CHARS=40000

RATE_LIMIT_TG_PER_MINUTE=60
AUDIT_RETENTION_MONTHS=24
DEFAULT_LATE_THRESHOLD_MINUTES=20
DEFAULT_WINDOW_START_OFFSET_MINUTES=-5
DEFAULT_WINDOW_DURATION_MINUTES=20
TEACHER_CORRECTION_WINDOW_DAYS=3
QR_DYNAMIC_SLOT_SECONDS=3
QR_DYNAMIC_GRACE_SLOTS=2
QR_DYNAMIC_TOKEN_SECRET=
BIOMETRIC_SIGNATURE_MAX_DRIFT_SECONDS=30
BIOMETRIC_NONCE_TTL_SECONDS=90
BIOMETRIC_PUBLIC_ENABLED=true

DEFAULT_ESCALATION_UNEXCUSED_ABSENCES=3
DEFAULT_ESCALATION_LATES=4
DEFAULT_ESCALATION_MIN_RATING=60
